{
  "name": "@harfai/cli",
  "version": "0.1.0",
  "description": "CLI for scaffolding Harfai projects and initializing AI agent configurations",
  "type": "module",
  "bin": {
    "create-harfai": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
